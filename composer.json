{
  "name": "tonegabes/filament-better-options",
  "description": "Filament form components for better radio and checkbox options.",
  "type": "library",
  "keywords": [
    "checkbox",
    "filament",
    "forms",
    "laravel",
    "plugin",
    "php",
    "tonegabes"
  ],
  "homepage": "https://github.com/tonegabes/filament-better-options",
  "support": {
    "issues": "https://github.com/tonegabes/filament-better-options/issues",
    "source": "https://github.com/tonegabes/filament-better-options"
  },
  "license": "MIT",
  "authors": [
    {
      "name": "Tone Gabes",
      "email": "tonegabes@gmail.com",
      "role": "Developer",
      "homepage": "https://tonegabes.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "filament/forms": "^5.0",
    "spatie/laravel-package-tools": "^1.15.0"
  },
  "require-dev": {
    "laravel/pint": "^1.0",
    "larastan/larastan": "^3.0",
    "phpstan/phpstan-deprecation-rules": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.86",
    "orchestra/testbench": "^9.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0",
    "tonegabes/filament-phosphor-icons": "^1.3"
  },
  "suggest": {
    "tonegabes/filament-phosphor-icons": "Use Phosphor icons as defaults for indicators instead of the built-in Heroicons fallback (^1.3)."
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "autoload": {
    "psr-4": {
      "ToneGabes\\BetterOptions\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ToneGabes\\BetterOptions\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "analyze": "vendor/bin/phpstan analyze",
    "format": "vendor/bin/pint",
    "test": "vendor/bin/pest",
    "test-coverage": "vendor/bin/pest --coverage"
  },
  "extra": {
    "laravel": {
      "providers": [
        "ToneGabes\\BetterOptions\\BetterOptionsServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
